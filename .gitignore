# Environment secrets — never commit
.env

# Python byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
*.egg-info/
dist/
build/
.eggs/

# pytest cache
.pytest_cache/

# virtual environments
.venv/
venv/
env/

# Inbound file inbox / archives — content is operational, not source
# Keep directory structure (via .gitkeep) but ignore any deposited files.
/data/inbox/*
!/data/inbox/.gitkeep
!/data/inbox/README.md
/data/processed/*
!/data/processed/.gitkeep
/data/rejected/*
!/data/rejected/.gitkeep
