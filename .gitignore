# Environment secrets — never commit
.env

# Raw ERP extracts — large input data, never commit (SALES_MARINE.full.tsv ~2.3 GB)
Raw Data/
*.tsv.rar
.valve_*.txt

# Python byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
*.egg-info/
dist/
build/
.eggs/

# pytest cache
.pytest_cache/

# virtual environments
.venv/
venv/
env/

# Inbound file inbox / archives — content is operational, not source
# Keep directory structure (via .gitkeep) but ignore any deposited files.
/data/inbox/*
!/data/inbox/.gitkeep
!/data/inbox/README.md
/data/processed/*
!/data/processed/.gitkeep
/data/rejected/*
!/data/rejected/.gitkeep

# Rust PoC build artifacts — sources are tracked, build output is not
poc/rust_kernel/target/

# Client data deliverables — operational payloads, not source
data-input-canonique-v1-*.zip

# Data-delivery notes that point at private workspace paths
/README.txt
